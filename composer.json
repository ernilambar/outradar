{
	"name": "ernilambar/outpulse",
	"description": "WordPress Outbound HTTP Request Tracker & Analyzer.",
	"license": "GPL-2.0-or-later",
	"type": "wordpress-plugin",
	"homepage": "https://github.com/ernilambar/outpulse",
	"require": {
		"php": ">=8.0"
	},
	"require-dev": {
		"ernilambar/coding-standard": "^1",
		"slevomat/coding-standard": "^8",
		"wp-cli/i18n-command": "^2.7",
		"wp-cli/wp-cli": "^2.13",
		"wp-coding-standards/wpcs": "^3.3"
	},
	"minimum-stability": "dev",
	"prefer-stable": true,
	"autoload": {
		"psr-4": {
			"Nilambar\\Outpulse\\": "app/"
		}
	},
	"config": {
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": true
		},
		"optimize-autoloader": true,
		"platform": {
			"php": "8.0"
		},
		"sort-packages": true
	},
	"scripts": {
		"format": "@php ./vendor/bin/phpcbf --report-full --report-summary",
		"lint": "@phpcs",
		"mo": "./vendor/bin/wp i18n make-mo languages/",
		"phpcs": "@php ./vendor/bin/phpcs --report-full --report-summary",
		"po": "./vendor/bin/wp i18n update-po languages/outpulse.pot languages/",
		"pot": "./vendor/bin/wp i18n make-pot . --exclude=build,deploy,node_modules,vendor --headers='{\"POT-Creation-Date\":\"\"}'"
	}
}
