{
	"name": "ernilambar/outradar",
	"description": "Log outbound HTTP requests.",
	"license": "GPL-2.0-or-later",
	"type": "wordpress-plugin",
	"homepage": "https://github.com/ernilambar/outradar",
	"require": {
		"php": ">=7.4"
	},
	"require-dev": {
		"dealerdirect/phpcodesniffer-composer-installer": "^1",
		"ernilambar/coding-standard": "^1",
		"php-parallel-lint/php-parallel-lint": "^1.4",
		"phpcompatibility/php-compatibility": "^10",
		"slevomat/coding-standard": "^8",
		"wp-cli/i18n-command": "^2.7",
		"wp-cli/wp-cli": "^2.13",
		"wp-coding-standards/wpcs": "^3.3"
	},
	"minimum-stability": "dev",
	"prefer-stable": true,
	"autoload": {
		"psr-4": {
			"Nilambar\\OutRadar\\": "app/"
		}
	},
	"config": {
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": true,
			"ergebnis/composer-normalize": true
		},
		"optimize-autoloader": true,
		"platform": {
			"php": "7.4"
		},
		"sort-packages": true
	},
	"scripts": {
		"format": "@php ./vendor/bin/phpcbf --report-full --report-summary",
		"lint": [
			"@lint-php",
			"@phpcs"
		],
		"lint-php": "@php ./vendor/bin/parallel-lint -p php --colors --exclude .git --exclude vendor .",
		"mo": "./vendor/bin/wp i18n make-mo languages/",
		"phpcs": "@php ./vendor/bin/phpcs --report-full --report-summary",
		"po": "./vendor/bin/wp i18n update-po languages/outradar.pot languages/",
		"pot": "./vendor/bin/wp i18n make-pot . --exclude=build,deploy,node_modules,vendor --headers='{\"POT-Creation-Date\":\"\"}'"
	}
}
