{
	"easyReplaceInFiles": [
		{
			"files": "$$package__main$$",
			"from": "Version:\\s?(.+)",
			"type": "regex",
			"to": "Version: $$npm_package_version$$"
		},
		{
			"files": "$$package__main$$",
			"from": "define\\( \\'OUTPULSE_VERSION\\'\\, \\'(.+)\\'",
			"type": "regex",
			"to": "define( 'OUTPULSE_VERSION', '$$npm_package_version$$'"
		}
	]
}
